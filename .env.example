OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_TIMEOUT_SECONDS=300
OPENAI_MAX_RETRIES=2
OPENAI_OVERVIEW_DETAIL=low
OPENAI_WINDOW_DETAIL=auto
OPENAI_REANALYSIS_DETAIL=high
OPENAI_FRAME_MAX_WIDTH=1280
OPENAI_JPEG_QUALITY=82
OPENAI_TARGET_WINDOW_SECONDS=12
OPENAI_MIN_WINDOW_SECONDS=5
OPENAI_MAX_WINDOW_SECONDS=20
OPENAI_MAX_FRAMES_PER_WINDOW_BASE=10
OPENAI_MAX_FRAMES_PER_WINDOW_REANALYSIS=18
OPENAI_WINDOW_SECONDS=12
OPENAI_MAX_FRAMES_PER_WINDOW=10
OPENAI_OVERVIEW_MAX_FRAMES=12
OPENAI_IMAGE_DETAIL_OVERVIEW=low
OPENAI_IMAGE_DETAIL_WINDOW=auto
MAX_CONTEXT_CHARS=18000
APP_ENV=local

LOG_LEVEL=INFO
DB_URL=sqlite:///./data/sps_analysis.db
VIDEO_FRAME_EXTRACTION_INTERVAL=1.0
VIDEO_RESOLUTION_TARGET=1920x1080
KNOWLEDGE_EMBEDDING_MODEL=text-embedding-3-small
